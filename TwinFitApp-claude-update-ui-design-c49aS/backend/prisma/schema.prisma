// TwinFit Prisma Schema — SQLite (local dev)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums (stored as String in SQLite) ──────────────────────────────────────

// Gender: MALE | FEMALE | OTHER
// Objective: BULKING | SLIMMING | MAINTENANCE | WELLNESS
// DietType: ANTI_INFLAMMATORY | BALANCED | HIGH_PROTEIN | NONE
// GymFrequency: ONE_TO_TWO | THREE_TO_FIVE | SIX_PLUS
// GroupMode: COUPLE | BESTIES | SQUAD | DUO
// MembershipStatus: INVITED | ACTIVE | LEFT
// CheckInStatus: PENDING | VALIDATED | REJECTED
// BadgeCategory: EXPLORATION | ENGAGEMENT | CONSISTENCY | SOCIAL
// NotificationType: STREAK | CHECKIN | MEAL | SOCIAL | SYSTEM | QUEST | DUMBBELL
// QuestFrequency: DAILY | WEEKLY | MONTHLY
// BorderRarity: COMMON | RARE | LEGENDARY | MYTHIC

// ─── Core models ──────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  phone         String?  @unique
  username      String   @unique
  name          String
  surname       String
  age           Int?
  gender        String?
  passwordHash  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       Profile?
  groups        GroupMember[]
  checkIns      CheckIn[]
  streaks       Streak[]
  badges        UserBadge[]
  mealScans     MealScan[]
  recipes       Recipe[]
  notifications Notification[]
  wallet        DumbbellWallet?
  questProgress UserQuestProgress[]
  ownedBorders  UserBorder[]
  xpBoosts      XpBoost[]
  transactions  DumbbellTransaction[]
}

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  avatarUrl      String?
  avatarEmoji    String?  @default("🦁")
  avatarType     String?  @default("emoji")
  bio            String?
  heightCm       Int?
  weightKg       Int?
  gymFrequency   String?
  objective      String?
  dietType       String?
  activeBorderId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Group {
  id         String      @id @default(cuid())
  name       String
  mode       String      @default("DUO")
  inviteCode String      @unique
  createdAt  DateTime    @default(now())

  members    GroupMember[]
  checkIns   CheckIn[]
  streaks    Streak[]
}

model GroupMember {
  id        String    @id @default(cuid())
  groupId   String
  userId    String
  status    String    @default("INVITED")
  joinedAt  DateTime?

  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model CheckIn {
  id         String   @id @default(cuid())
  userId     String
  groupId    String?
  photoUrl   String
  status     String   @default("PENDING")
  capturedAt DateTime
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group      Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Streak {
  id          String    @id @default(cuid())
  userId      String?
  groupId     String?
  current     Int       @default(0)
  longest     Int       @default(0)
  weeklyCount Int       @default(0)
  level       Int       @default(1)
  lastLogDate DateTime?
  updatedAt   DateTime  @updatedAt

  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       Group?    @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String      @id @default(cuid())
  code        String      @unique
  category    String
  title       String
  description String?
  icon        String?

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model MealScan {
  id          String   @id @default(cuid())
  userId      String
  description String
  photoUrl    String?
  calories    Int      @default(0)
  protein     Int      @default(0)
  carbs       Int      @default(0)
  fat         Int      @default(0)
  healthScore Int?
  scannedAt   DateTime @default(now())
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Recipe {
  id          String   @id @default(cuid())
  userId      String
  name        String
  ingredients String   // JSON array stored as text
  steps       String   // JSON array stored as text
  calories    Int      @default(0)
  protein     Int      @default(0)
  carbs       Int      @default(0)
  fat         Int      @default(0)
  goal        String?
  saved       Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Dumbbell Economy ─────────────────────────────────────────────────────────

model DumbbellWallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  balance     Int      @default(0)
  totalEarned Int      @default(0)
  xp          Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DumbbellTransaction {
  id           String   @id @default(cuid())
  userId       String
  amount       Int
  reason       String
  balanceAfter Int
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Quest {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  description String
  reward      Int
  xpReward    Int
  frequency   String
  icon        String

  progress    UserQuestProgress[]
}

model UserQuestProgress {
  id        String    @id @default(cuid())
  userId    String
  questId   String
  periodKey String
  progress  Float     @default(0)
  completed Boolean   @default(false)
  claimedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest     Quest     @relation(fields: [questId], references: [id])

  @@unique([userId, questId, periodKey])
}

model Border {
  id          String   @id @default(cuid())
  code        String   @unique
  label       String
  description String
  cost        Int
  rarity      String
  color       String
  color2      String?
  icon        String

  owners      UserBorder[]
}

model UserBorder {
  id          String   @id @default(cuid())
  userId      String
  borderId    String
  purchasedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  border      Border   @relation(fields: [borderId], references: [id])

  @@unique([userId, borderId])
}

model XpBoost {
  id         String   @id @default(cuid())
  userId     String
  multiplier Float
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
