// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Objective {
  BULKING
  SLIMMING
  MAINTENANCE
  WELLNESS
}

enum DietType {
  ANTI_INFLAMMATORY
  BALANCED
  HIGH_PROTEIN
  NONE
}

enum GymFrequency {
  ONE_TO_TWO
  THREE_TO_FIVE
  SIX_PLUS
}

enum GroupMode {
  COUPLE
  BESTIES
  SQUAD
}

enum MembershipStatus {
  INVITED
  ACTIVE
  LEFT
}

enum CheckInStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum BadgeCategory {
  EXPLORATION
  ENGAGEMENT
  CONSISTENCY
  SOCIAL
}

enum NotificationType {
  STREAK
  CHECKIN
  MEAL
  SOCIAL
  SYSTEM
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  phone         String?        @unique
  username      String         @unique
  name          String
  surname       String
  age           Int?
  gender        Gender?
  passwordHash  String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  profile       Profile?
  groups        GroupMember[]
  checkIns      CheckIn[]
  streaks       Streak[]
  badges        UserBadge[]
  mealScans     MealScan[]
  recipes       Recipe[]
  notifications Notification[]
}

model Profile {
  id             String        @id @default(cuid())
  userId         String        @unique
  avatarUrl      String?
  avatarType     String?       @default("avatar")
  bio            String?
  heightCm       Int?
  weightKg       Int?
  gymFrequency   GymFrequency?
  objective      Objective?
  dietType       DietType?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id])
}

model Group {
  id         String         @id @default(cuid())
  name       String
  mode       GroupMode
  inviteCode String         @unique
  createdAt  DateTime       @default(now())

  members    GroupMember[]
  checkIns   CheckIn[]
  streaks    Streak[]
}

model GroupMember {
  id        String           @id @default(cuid())
  groupId   String
  userId    String
  status    MembershipStatus @default(INVITED)
  joinedAt  DateTime?

  group     Group            @relation(fields: [groupId], references: [id])
  user      User             @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model CheckIn {
  id         String        @id @default(cuid())
  userId     String
  groupId    String
  photoUrl   String
  status     CheckInStatus @default(PENDING)
  capturedAt DateTime
  createdAt  DateTime      @default(now())

  user       User          @relation(fields: [userId], references: [id])
  group      Group         @relation(fields: [groupId], references: [id])
}

model Streak {
  id          String   @id @default(cuid())
  userId      String?
  groupId     String?
  current     Int      @default(0)
  weeklyCount Int      @default(0)
  level       Int      @default(1)
  updatedAt   DateTime @updatedAt

  user        User?    @relation(fields: [userId], references: [id])
  group       Group?   @relation(fields: [groupId], references: [id])
}

model Badge {
  id          String        @id @default(cuid())
  code        String        @unique
  category    BadgeCategory
  title       String
  description String?
  icon        String?

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model MealScan {
  id           String   @id @default(cuid())
  userId       String
  imageUrl     String
  summary      String
  proteinScore Int
  carbsScore   Int
  fibersScore  Int
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])
}

model Recipe {
  id          String   @id @default(cuid())
  userId      String
  title       String
  steps       String[]
  ingredients String[]
  saved       Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id])
}
